import numpy as np
import matplotlib.pyplot as plt
from scipy.fft import fft, fftfreq

# Parámetros
fs = 1000  # Frecuencia de muestreo
t = np.linspace(0, 1, fs)

# Señal de mensaje (baja frecuencia)
fm = 5  # Hz
mensaje = np.sin(2 * np.pi * fm * t)

# Señal portadora (alta frecuencia)
fc = 50  # Hz
portadora = np.cos(2 * np.pi * fc * t)

# Modulación AM
modulada = (1 + mensaje) * portadora

# Ruido (Gaussiano)
ruido = np.random.normal(0, 0.3, len(t))
modulada_ruido = modulada + ruido

# Atenuación
atenuada = 0.5 * modulada

# FUNCIÓN FFT
def calcular_fft(signal):
    N = len(signal)
    yf = fft(signal)
    xf = fftfreq(N, 1/fs)
    return xf[:N//2], np.abs(yf[:N//2])

# FFTs
xf_m, yf_m = calcular_fft(mensaje)
xf_mod, yf_mod = calcular_fft(modulada)

# GRÁFICAS

plt.figure(figsize=(12,10))

# Señal de mensaje
plt.subplot(3,2,1)
plt.plot(t, mensaje)
plt.title("Señal de Mensaje")

# Señal portadora
plt.subplot(3,2,2)
plt.plot(t, portadora)
plt.title("Señal Portadora")

# Señal modulada
plt.subplot(3,2,3)
plt.plot(t, modulada)
plt.title("Señal Modulada AM")

# Señal con ruido
plt.subplot(3,2,4)
plt.plot(t, modulada_ruido)
plt.title("Señal con Ruido")

# Señal atenuada
plt.subplot(3,2,5)
plt.plot(t, atenuada)
plt.title("Señal Atenuada")

plt.tight_layout()
plt.show()

# FRECUENCIA

plt.figure()

plt.subplot(2,1,1)
plt.plot(xf_m, yf_m)
plt.title("FFT Señal de Mensaje")

plt.subplot(2,1,2)
plt.plot(xf_mod, yf_mod)
plt.title("FFT Señal Modulada")

plt.tight_layout()
plt.show()

